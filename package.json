{
  "name": "medalmap",
  "version": "1.0.0",
  "description": "Web app showing where Olympic medalists were born.",
  "author": "Vegard Egeland",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "check": "biome check .",
    "check:fix": "biome check . --write",
    "lint": "biome lint .",
    "lint:fix": "biome lint . --write",
    "format": "biome format .",
    "format:fix": "biome format . --write",
    "typecheck": "tsc",
    "test": "vitest",
    "test:run": "vitest run",
    "pipeline:wikipedia": "tsx scripts/wikipedia.ts",
    "pipeline:wikidata": "tsx scripts/wikidata.ts",
    "pipeline:coverage": "tsx scripts/coverage.ts",
    "pipeline:merge": "tsx scripts/merge.ts"
  },
  "dependencies": {
    "maplibre-gl": "^5.20.2",
    "preact": "^10.29.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@preact/preset-vite": "^2.10.4",
    "@types/node": "^25.5.0",
    "node-html-parser": "^7.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  }
}
