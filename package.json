{
  "name": "medalmap",
  "version": "1.0.0",
  "description": "Web app showing where Olympic medalists were born.",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc",
    "test": "vitest",
    "test:run": "vitest run",
    "pipeline:wikipedia": "tsx scripts/wikipedia.ts",
    "pipeline:wikidata": "tsx scripts/wikidata.ts",
    "pipeline:coverage": "tsx scripts/coverage.ts",
    "pipeline:merge": "tsx scripts/merge.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vegardege/medalmap.git"
  },
  "keywords": [],
  "author": "Vegard Egeland",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/vegardege/medalmap/issues"
  },
  "homepage": "https://medalmap.pebblepatch.dev",
  "dependencies": {
    "maplibre-gl": "^5.19.0",
    "preact": "^10.28.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@preact/preset-vite": "^2.10.3",
    "@types/node": "^25.3.0",
    "node-html-parser": "^7.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
